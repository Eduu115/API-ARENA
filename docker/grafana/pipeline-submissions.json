      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"submission-service|sandbox-service|testing-service\",status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "5xx errors / sec (pipeline)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
