      "title": "HTTP throughput (submission / sandbox / testing)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_sum{job=~\"submission-service|sandbox-service|testing-service\"}[5m])) / sum by (job) (rate(http_server_requests_seconds_count{job=~\"submission-service|sandbox-service|testing-service\"}[5m]))",
          "legendFormat": "{{job}} avg latency (s)",
          "refId": "A"
        }
      ],
      "title": "HTTP avg latency by service (from summary)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" }, "overrides": [] },
