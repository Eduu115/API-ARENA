# ===========================================
# APIArena - Environment Variables
# ===========================================

# ⚠️ All secrets below are DEV-ONLY placeholders. Generate fresh values for any
#    real/public deployment (e.g. `openssl rand -base64 32`) and never commit them.

# PostgreSQL
POSTGRES_DB=apiarena
POSTGRES_USER=apiarena_user
POSTGRES_PASSWORD=dev-only-change-me-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=dev-only-change-me-redis-password
REDIS_HOST=redis
REDIS_PORT=6379

# MongoDB
MONGO_USER=apiarena_mongo
MONGO_PASSWORD=mongosecret789
MONGO_DATABASE=apiarena_logs
MONGO_HOST=mongodb
MONGO_PORT=27017

# InfluxDB
INFLUX_USER=apiarena_admin
INFLUX_PASSWORD=influxsecret101
INFLUX_ORG=apiarena
INFLUX_BUCKET=metrics
INFLUX_TOKEN=myinfluxtoken112233445566
INFLUX_HOST=influxdb
INFLUX_PORT=8086

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# JWT — Base64-decoded into the HMAC signing key (>= 32 bytes decoded).
# DEV-ONLY value; in prod generate a unique one: `openssl rand -base64 48`
JWT_SECRET=Y9Wv860IGQ3ue96EQYS6yTUzxItkrjkFtTJPUzB8wPwxag6bLfQSBxkuLcgpMVm2
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Internal service-to-service shared secret (REQUIRED). Guards on /internal/** reject
# the old default "apiarena-internal-token". DEV-ONLY value below; rotate in prod:
# `openssl rand -base64 32`
INTERNAL_SERVICE_TOKEN=dev-only-change-me-internal-service-token

# Swagger / OpenAPI — enabled for local dev/CI; leave UNSET in prod (defaults to off).
SPRINGDOC_ENABLED=true

# API Keys (BONUS Features)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
AI_REVIEW_PROVIDER=heuristic
AI_REVIEW_MODEL=gemini-2.0-flash
AI_REVIEW_GOOGLE_API_KEY=
AI_REVIEW_TIMEOUT_MS=12000

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafanapass123

# Domain (cambiar por tu dominio)
DOMAIN=localhost
API_URL=http://localhost:8080
# Public SPA URL (also used in Resend reset/verify links via docker-compose)
FRONTEND_URL=http://localhost:3000

# Docker published ports/bind (optional)
# In production behind Nginx Proxy Manager, set BIND_IP=127.0.0.1 to avoid exposing services publicly.
BIND_IP=0.0.0.0

# Frontend build-time URLs (Vite)
VITE_AUTH_API_URL=http://localhost:8081
VITE_CHALLENGES_API_URL=http://localhost:8082
VITE_SUBMISSIONS_API_URL=http://localhost:8083
VITE_LEADERBOARD_API_URL=http://localhost:8087
VITE_NOTIFICATIONS_API_URL=http://localhost:8090
VITE_METRICS_API_URL=http://localhost:8089

# Cloudflare Turnstile (login / register)
# Production keys only work on hostnames configured in Cloudflare (e.g. apiarena.net).
# Local dev: leave empty (no widget) or use Cloudflare test keys (always pass on any host):
#   VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CORS (Spring Boot maps cors.allowed-origins <- CORS_ALLOWED_ORIGINS)
# For production behind NPM: https://apiarena.net
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (Resend — https://resend.com)
RESEND_API_KEY=api_key_here
# From address: use onboarding@resend.dev until apiarena.net is verified in Resend Domains.
APP_EMAIL_FROM=API Arena <noreply@apiarena.net>
# NGINX
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Sandbox DinD (optional hardening)
SANDBOX_DIND_USE_INIT=true
SANDBOX_DIND_NOFILE_ULIMIT=65536

# Metrics — scheduled BI CSV export (yesterday UTC) to /app/bi-exports in container
METRICS_BI_EXPORT_ENABLED=false
METRICS_BI_EXPORT_CRON=0 15 2 * * *
METRICS_BI_EXPORT_DIRECTORY=/app/bi-exports
METRICS_BI_EXPORT_ROW_LIMIT=500000

# Submission replay archive (MongoDB) + pipeline metrics (InfluxDB 2)
REPLAY_MONGODB_ENABLED=true
INFLUX_ENABLED=true
# Grafana Influx datasource (docker/grafana/provisioning/datasources/influxdb.yml) uses the same token as INFLUX_TOKEN for local dev.

# Alertmanager UI (Prometheus alerting)
# ALERTMANAGER_… — optional; see docker/alertmanager/alertmanager.yml for webhook receivers