# Single API origin (build-time, Vite).
# Leave EMPTY for Docker/prod and for `npm run dev`: the SPA uses same-origin /api/*,
# which the frontend nginx (prod) or Vite proxy (dev) routes to each service.
# Set only to hit a backend on another origin directly, e.g. http://localhost:8081.
VITE_API_BASE_URL=

# Cloudflare Turnstile (login / register)
VITE_TURNSTILE_SITE_KEY=
